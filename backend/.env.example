PORT=3001
NODE_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=focusradar
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# ── JWT (OBRIGATÓRIO — copie e cole valores diferentes para cada um) ───
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=cole_aqui_uma_string_longa_e_aleatoria
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=cole_aqui_outra_string_diferente_da_de_cima
REFRESH_TOKEN_EXPIRES_IN=7d

# ── E-mail ─────────────────────────────────────────────────────────────
# Em desenvolvimento: deixe SMTP_HOST vazio para usar o fallback do console
# Para usar Mailtrap: preencha com suas credenciais de https://mailtrap.io
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FocusRadar <no-reply@focusradar.app>"

# ── Frontend ───────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173
